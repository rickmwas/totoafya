{
  "name": "base44-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mother": "npm run dev --workspace=apps/mother-portal",
    "dev:nurse": "npm run dev --workspace=apps/nurse-portal",
    "dev:facility": "npm run dev --workspace=apps/facility-pc",
    "build:mother": "npm run build --workspace=apps/mother-portal",
    "build:nurse": "npm run build --workspace=apps/nurse-portal",
    "build:facility": "npm run build --workspace=apps/facility-pc",
    "tauri:facility": "npm run tauri --workspace=apps/facility-pc"
  }
}
